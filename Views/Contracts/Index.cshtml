@model IEnumerable<TechMoveSystem.Models.Contract>

<div class="container mt-4 pb-5 border-bottom border-5 border-warning bg-white shadow-sm rounded p-4">
    
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="text-navy fw-bold"><i class="bi bi-file-earmark-lock-fill text-warning"></i> Management: Contracts</h2>
            <p class="text-muted mb-0">Filter agreements, download file server agreements, or initiate service routing.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-warning fw-bold px-4 shadow-sm border-2 border-navy">
                <i class="bi bi-file-earmark-plus"></i> NEW AGREEMENT
            </a>
        </div>
    </div>

    <div class="card bg-light border border-navy mb-4 shadow-sm">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-navy">Executed From Date</label>
                    <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control form-control-sm border-navy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-navy">Executed To Date</label>
                    <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control form-control-sm border-navy" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-navy">Status State</label>
                    <select name="statusFilter" class="form-select form-select-sm border-navy">
                        <option value="">-- All Framework States --</option>
    
                        @if (ViewBag.StatusFilter == "Draft")
                        {
                            <option value="Draft" selected>Draft Mode</option>
                        }
                        else
                        {
                            <option value="Draft">Draft Mode</option>
                        }
    
                        @if (ViewBag.StatusFilter == "Active")
                        {
                            <option value="Active" selected>Active Operational</option>
                        }
                        else
                        {
                            <option value="Active">Active Operational</option>
                        }
    
                        @if (ViewBag.StatusFilter == "Expired")
                        {
                            <option value="Expired" selected>Expired</option>
                        }
                        else
                        {
                            <option value="Expired">Expired</option>
                        }
    
                        @if (ViewBag.StatusFilter == "On Hold")
                        {
                            <option value="On Hold" selected>On Hold</option>
                        }
                        else
                        {
                            <option value="On Hold">On Hold</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-navy text-white fw-bold w-100 shadow-sm">
                        <i class="bi bi-funnel-fill text-warning"></i> FILTER
                    </button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100 shadow-sm">RESET</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow overflow-hidden">
        <table class="table mb-0 align-middle table-hover">
            <thead class="bg-navy text-white">
                <tr>
                    <th class="py-3 ps-4">Contract Tracking</th>
                    <th class="py-3">Client Partner Name</th>
                    <th class="py-3">Service Level</th>
                    <th class="py-3">Operating Window</th>
                    <th class="py-3">Status</th>
                    <th class="py-3 pe-4 text-end">Operational Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted italic">No legal framework contracts found matching criteria.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="border-bottom">
                        <td class="ps-4 fw-bold text-navy">#@item.Id</td>
                        <td class="fw-semibold text-secondary">@(item.Client?.Name ?? "Unlinked Entity")</td>
                        <td><span class="badge bg-light text-navy border border-navy">@item.ServiceLevel</span></td>
                        <td class="small text-muted">
                            @item.StartDate.ToString("dd MMM yyyy") &rarr; @item.EndDate.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            @{
                                var statusStyle = item.Status == "Active" ? "bg-success text-white" :
                                                  item.Status == "Expired" ? "bg-danger text-white" : "bg-warning text-dark";
                            }
                            <span class="badge rounded-pill @statusStyle px-3">@item.Status</span>
                        </td>
                        <td class="pe-4 text-end">
                            <div class="btn-group shadow-sm">
                                @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                                {
                                    <a href="@item.SignedAgreementPath" class="btn btn-sm btn-outline-navy fw-bold" download>
                                        <i class="bi bi-file-earmark-pdf-fill text-danger"></i> PDF
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" disabled>No File</button>
                                }

                                @if (item.Status != "Expired" && item.Status != "On Hold")
                                {
                                    <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@item.Id"
                                       class="btn btn-sm btn-navy fw-bold">
                                        + REQUEST
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-secondary opacity-50" disabled title="Workflow Locked: Contract status prevents active dispatch logging.">
                                        LOCKED
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>