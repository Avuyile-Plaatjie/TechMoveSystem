@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <span class="nav-link text-white fw-semibold me-3"><i class="bi bi-person-circle"></i> Hello, @UserManager.GetUserName(User)!</span>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="btn btn-sm btn-outline-warning fw-bold border-2 px-3">LOGOUT</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-white fw-semibold" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item ms-2">
            <a class="btn btn-sm btn-warning text-navy fw-bold border-2 border-navy px-3" asp-area="Identity" asp-page="/Account/Login">LOGIN</a>
        </li>
    }
</ul>
