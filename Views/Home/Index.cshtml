@{
    ViewData["Title"] = "Dashboard Hub";
}

<div class="container mt-2 pb-5">
    <div class="p-5 mb-4 bg-navy text-white rounded-3 position-relative overflow-hidden shadow-lg border-bottom border-5 border-warning">
        <div class="row align-items-center position-relative" style="z-index: 2;">
            <div class="col-md-8">
                <h1 class="display-5 fw-bold">TechMove Command Center</h1>
                <p class="col-md-12 fs-5 opacity-75">Welcome back to the unified enterprise management platform. Monitor logistics profiles, service agreements, and track financial multi-currency pipelines.</p>
            </div>
            <div class="col-md-4 text-end d-none d-md-block">
                <i class="bi bi-shield-lock text-warning opacity-50" style="font-size: 7rem;"></i>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm border-start border-4 border-primary">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title text-muted fw-bold mb-0">CLIENT REGISTRY</h5>
                        <i class="bi bi-people-fill text-primary fs-3"></i>
                    </div>
                    <p class="card-text small text-secondary">Manage registered transport entities, contact metadata profiles, and assigned provinces.</p>
                    <a asp-controller="Clients" asp-action="Index" class="btn btn-sm btn-navy fw-bold mt-2">LAUNCH HUB &rarr;</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm border-start border-4 border-warning">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title text-muted fw-bold mb-0">LEGAL FRAMEWORKS</h5>
                        <i class="bi bi-file-earmark-lock-fill text-warning fs-3"></i>
                    </div>
                    <p class="card-text small text-secondary">Monitor contract operating windows, process file server PDF agreements, and maintain status flows.</p>
                    <a asp-controller="Contracts" asp-action="Index" class="btn btn-sm btn-warning text-navy border border-navy fw-bold mt-2">LAUNCH HUB &rarr;</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm border-start border-4 border-success">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title text-muted fw-bold mb-0">SERVICE DISPATCH</h5>
                        <i class="bi bi-speedometer2 text-success fs-3"></i>
                    </div>
                    <p class="card-text small text-secondary">Log operational dispatch entries, convert currency exchange parameters, and verify job logs.</p>
                    <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-sm btn-navy fw-bold mt-2">LAUNCH HUB &rarr;</a>
                </div>
            </div>
        </div>
    </div>
</div>