@model TechMoveSystem.Models.ServiceRequest

<div class="container mt-4 pb-5">
    <div class="card shadow-lg border-0 page-container-footer">
        
        <div class="card-header bg-navy text-white py-3 border-bottom border-4 border-warning">
            <div class="row align-items-center">
                <div class="col">
                    <h4 class="mb-0 fw-bold text-uppercase">
                        <i class="bi bi-info-circle-fill text-warning me-2"></i> Service Request Blueprint
                    </h4>
                    <p class="small opacity-75 mb-0 mt-1">System Dispatch Log ID: #@Model.Id</p>
                </div>
                <div class="col-auto">
                    <span class="badge bg-warning text-navy fw-bold px-3 py-2 border border-2 border-navy">
                        STATUS: @Model.Status
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body p-4 bg-white">
            <div class="row mb-4">
                
                <div class="col-md-6 border-end">
                    <h5 class="text-navy fw-bold mb-3 border-bottom pb-1">
                        <i class="bi bi-building"></i> Associated Fleet Partner
                    </h5>
                    <dl class="row small">
                        <dt class="col-sm-4 text-muted">Client Name:</dt>
                        <dd class="col-sm-8 fw-bold text-secondary">
                            @(Model.Contract?.Client?.Name ?? "Unlinked System Entity")
                        </dd>

                        <dt class="col-sm-4 text-muted">Contract Reference:</dt>
                        <dd class="col-sm-8 fw-semibold text-navy">
                            #@(Model.Contract?.Id ?? 0) (Tier: @(Model.Contract?.ServiceLevel ?? "N/A"))
                        </dd>

                        <dt class="col-sm-4 text-muted">Operating Window:</dt>
                        <dd class="col-sm-8 text-muted">
                            @Model.Contract?.StartDate.ToString("dd MMM yyyy") &rarr; @Model.Contract?.EndDate.ToString("dd MMM yyyy")
                        </dd>
                    </dl>
                </div>

                <div class="col-md-6 ps-4">
                    <h5 class="text-navy fw-bold mb-3 border-bottom pb-1">
                        <i class="bi bi-cash-stack"></i> Financial Allocation
                    </h5>
                    <dl class="row small">
                        <dt class="col-sm-5 text-muted">Base Cost (USD):</dt>
                        <dd class="col-sm-7 fw-bold text-success">
                            $@Model.CostInUsd.ToString("N2")
                        </dd>

                        <dt class="col-sm-5 text-muted">Converted Cost (ZAR):</dt>
                        <dd class="col-sm-7 fw-bold text-navy">
                            R @Model.CostInZar.ToString("N2")
                        </dd>

                        <dt class="col-sm-5 text-muted">Exchange Conversion:</dt>
                        <dd class="col-sm-7 text-muted small italic">
                            Processed dynamically via Currency API
                        </dd>
                    </dl>
                </div>

            </div>

            <div class="bg-light p-3 rounded border border-navy mb-4">
                <h6 class="fw-bold text-navy mb-2"><i class="bi bi-card-text"></i> Assignment & Service Request Description</h6>
                <p class="mb-0 text-secondary small style="white-space: pre-line;">@Model.Description</p>
            </div>

            <div class="d-flex justify-content-between align-items-center border-top pt-3">
                <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm">
                    <i class="bi bi-arrow-left"></i> Back to Dispatch List
                </a>
                
                @if (Model.Contract?.SignedAgreementPath != null)
                {
                    <a href="@Model.Contract.SignedAgreementPath" class="btn btn-navy text-white fw-bold shadow-sm" download>
                        <i class="bi bi-file-pdf-fill text-danger"></i> Download Legal Agreement
                    </a>
                }
            </div>

        </div>
    </div>
</div>