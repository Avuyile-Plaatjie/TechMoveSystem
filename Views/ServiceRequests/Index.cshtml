@model IEnumerable<TechMoveSystem.Models.ServiceRequest>

<div class="container mt-4 pb-5 border-bottom border-5 border-warning bg-white shadow-sm rounded p-4">
    
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="text-navy fw-bold"><i class="bi bi-speedometer2 text-warning"></i> Service Dispatch Control</h2>
            <p class="text-muted mb-0">Monitor live technical service logs, tracking financial conversions and active dispatches.</p>
        </div>
    </div>

    <div class="card bg-light border border-navy mb-4 shadow-sm">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small fw-bold text-navy">Search Request Description</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-navy text-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" value="@ViewBag.CurrentSearch" placeholder="Type keywords..." class="form-control border-navy" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-navy">Dispatch Status State</label>
                    <select name="statusFilter" class="form-select form-select-sm border-navy">
                        <option value="">-- All Statuses --</option>
                        @if (ViewBag.CurrentStatus == "Pending")
                        {
                            <option value="Pending" selected>Pending Verification</option>
                        }
                        else
                        {
                            <option value="Pending">Pending Verification</option>
                        }
                        
                        @if (ViewBag.CurrentStatus == "Approved")
                        {
                            <option value="Approved" selected>Approved / Active</option>
                        }
                        else
                        {
                            <option value="Approved">Approved / Active</option>
                        }
                        
                        @if (ViewBag.CurrentStatus == "Completed")
                        {
                            <option value="Completed" selected>Completed Job</option>
                        }
                        else
                        {
                            <option value="Completed">Completed Job</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-sm btn-navy text-white fw-bold w-100 shadow-sm">
                        <i class="bi bi-funnel-fill text-warning"></i> FILTER
                    </button>
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary w-100 shadow-sm">RESET</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow overflow-hidden">
        <table class="table mb-0 align-middle table-hover">
            <thead class="bg-navy text-white">
                <tr>
                    <th class="py-3 ps-4">Log ID</th>
                    <th class="py-3">Client Partner</th>
                    <th class="py-3">Description Snippet</th>
                    <th class="py-3">Cost (USD)</th>
                    <th class="py-3">Cost (ZAR)</th>
                    <th class="py-3">Status</th>
                    <th class="py-3 pe-4 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted italic">No service logs dispatched matching selection criteria.</td>
                    </tr>
                }
                @foreach (var item in Model)
                {
                    <tr class="border-bottom">
                        <td class="ps-4 fw-bold text-navy">#@item.Id</td>
                        <td class="fw-semibold text-secondary">
                            @(item.Contract?.Client?.Name ?? "Unlinked Profile")
                        </td>
                        <td class="small text-truncate" style="max-width: 200px;">
                            @item.Description
                        </td>
                        <td class="fw-bold text-success small">$@item.CostInUsd.ToString("N2")</td>
                        <td class="fw-bold text-navy small">R @item.CostInZar.ToString("N2")</td>
                        <td>
                            <span class="badge bg-light text-navy border border-warning px-2 py-1 small">
                                <i class="bi bi-hourglass-split text-warning me-1"></i> @item.Status
                            </span>
                        </td>
                        <td class="pe-4 text-center">
                            <a asp-controller="ServiceRequests" asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-warning fw-bold text-navy border border-navy shadow-sm px-3">
                                <i class="bi bi-eye-fill"></i> VIEW DETAILS
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>