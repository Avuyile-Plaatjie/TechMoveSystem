@model TechMoveSystem.Models.ServiceRequest

<div class="container mt-4 pb-5 border-bottom border-5 border-navy bg-white shadow-sm rounded">
    <h2 class="text-navy fw-bold p-3">Log Service Request</h2>

    <form asp-action="Create" class="p-3">
        <input type="hidden" asp-for="ContractId" value="@ViewBag.ContractId" />

        <div class="mb-3">
            <label asp-for="Description" class="form-label fw-bold"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label asp-for="CostInUsd" class="form-label fw-bold">Amount in USD ($)</label>
            <input asp-for="CostInUsd" class="form-control" type="number" step="0.01" placeholder="e.g. 150.00" />
            <div class="form-text text-info">This will be auto-converted to ZAR upon saving.</div>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-warning fw-bold">CALCULATE & SAVE</button>
            <a asp-controller="Contracts" asp-action="Index" class="btn btn-link">Cancel</a>
        </div>
    </form>
</div>