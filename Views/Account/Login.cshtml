@{
    ViewData["Title"] = "Login";
}
<div class="container mt-5" style="max-width: 480px;">
    <div class="card shadow border-0">
        <div class="card-header bg-navy text-white border-bottom border-4 border-warning">
            <h4 class="mb-0">TechMove Login</h4>
        </div>
        <div class="card-body p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Username</label>
                    <input name="username" class="form-control" value="admin" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Password</label>
                    <input name="password" type="password" class="form-control" value="Admin123" />
                </div>
                <button class="btn btn-warning fw-bold w-100" type="submit">LOGIN</button>
            </form>
        </div>
    </div>
</div>
