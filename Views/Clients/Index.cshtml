@model IEnumerable<TechMoveSystem.Models.Client>

<div class="container mt-4 page-container-footer bg-white shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-navy">Client Registry</h2>
            <p class="text-muted">Manage official logistics partners and regional coverage.</p>
        </div>

        <a asp-action="Create" class="btn btn-warning fw-bold shadow-sm border-2 border-navy px-4">
            <i class="bi bi-person-plus-fill"></i> + ADD NEW CLIENT
        </a>
    </div>

    <div class="card border-0 shadow">
        <table class="table mb-0">
            <thead class="bg-navy text-white">
                <tr>
                    <th class="ps-4">Name</th>
                    <th>Contact</th>
                    <th>Region</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="align-middle">
                        <td class="ps-4 fw-bold">@item.Name</td>
                        <td>@item.ContactDetails</td>
                        <td><span class="badge bg-primary">@item.Region</span></td>
                        <td class="text-end pe-4">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>